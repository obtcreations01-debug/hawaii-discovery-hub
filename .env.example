# ----------------------------------------------------------------------------
# Hawaii Discovery Hub — environment variables
# Copy this file to `.env` for local dev, or set these on Railway / Heroku /
# DigitalOcean as project variables.
# ----------------------------------------------------------------------------

# Server
PORT=5000
NODE_ENV=development

# Database — Railway / Heroku / Render set DATABASE_URL automatically.
# For local dev, either set DATABASE_URL or the discrete DB_* vars below.
DATABASE_URL=postgresql://user:password@host:5432/hawaii_discovery

# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=hawaii_discovery

# JWT secrets — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-me
JWT_REFRESH_SECRET=replace-me-too
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# Stripe — get from https://dashboard.stripe.com/apikeys
# Optional: payments features won't work without these, but the rest of
# the app boots fine.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Frontend URL — used for CORS and Stripe redirect URLs.
# Set to your deployed origin in production. For local dev, leave as is.
FRONTEND_URL=http://localhost:5000
